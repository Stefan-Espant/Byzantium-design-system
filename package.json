{
  "name": "byzantium",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "docs": "pnpm --filter docs dev",
    "build": "pnpm --filter @byzantium/core build",
    "vercel-build": "sh ./vercel-build.sh",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @byzantium/core typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0",
    "eslint": "^9.0.0"
  }
}
