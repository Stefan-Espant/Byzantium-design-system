{
  "name": "@byzantium-design-system/core",
  "version": "0.1.0",
  "description": "Byzantium design system — tokens, components and patterns",
  "license": "MIT",
  "type": "module",
  "main": "./dist/byzantium.umd.cjs",
  "module": "./dist/byzantium.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/byzantium.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/byzantium.umd.cjs"
      }
    },
    "./styles": "./src/styles/index.scss"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Byzantium-design-system/Byzantium-design-system.git",
    "directory": "packages/byzantium"
  },
  "homepage": "https://github.com/Byzantium-design-system/Byzantium-design-system#readme",
  "bugs": {
    "url": "https://github.com/Byzantium-design-system/Byzantium-design-system/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:icons": "node ../../scripts/generate-icon-sprite.mjs",
    "build": "pnpm run generate:icons && vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "axe-core": "^4.10.0",
    "jsdom": "^25.0.0",
    "lucide-vue-next": "^1.0.0",
    "sass": "^1.80.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vitest-axe": "^0.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
